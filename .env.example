# ============================================
# AI Dev Pipeline - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入真实值
# 所有变量需要同时配置在:
#   1. n8n 环境变量
#   2. GitHub Repository Secrets
# ============================================

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=ClaytonPetrosian/ai-dev-pipeline

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- 飞书 (Feishu/Lark) ---
FEISHU_APP_ID=cli_aaacd2986d38dbea
FEISHU_APP_SECRET=ouTrr6BTrZrrm1gXTWBqmdMG6VCHeOZW
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxx  # 飞书群聊 Chat ID

# --- Notion ---
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- n8n ---
N8N_WEBHOOK_BASE=https://your-n8n-domain.up.railway.app/webhook
WEBHOOK_TOKEN=your-random-secret-token

# --- Sentry (崩溃监控) ---
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-org-slug

# --- App Store Connect ---
APPLE_ID=your@email.com
APPLE_TEAM_ID=XXXXXXXXXX
APP_BUNDLE_ID=com.yourcompany.yourapp
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_API_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APPLE_CERTIFICATE_P12=base64-encoded-p12
APPLE_CERTIFICATE_PASSWORD=p12-password
APPLE_PROVISIONING_PROFILE=base64-encoded-profile

# --- Match (代码签名) ---
MATCH_PASSWORD=your-match-password
MATCH_GIT_PRIVATE_KEY=your-git-ssh-key
